# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/familyfinplan

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# Email Configuration (for verification & password reset)
# Use Gmail: Enable 2FA → Create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Frontend URL (for CORS & email links)
FRONTEND_URL=https://gromofinance.com

# Max family members allowed
MAX_FAMILY_MEMBERS=6

# Google OAuth (for Sign in with Google)
GOOGLE_CLIENT_ID=699119480465-k5p2p39b9o5ps6fvs3brj5qqi0qjahjp.apps.googleusercontent.com

# Razorpay Payment Gateway (get keys from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Super Admin credentials (for /api/admin routes)
SUPER_ADMIN_EMAIL=admin@gromofinance.com
SUPER_ADMIN_PASSWORD=YourSuperAdminPassword123
